# ===================================
# 如意基金分析 - 环境变量配置模板
# 复制此文件为 .env 并填入真实配置
# ===================================

# 自选基金列表（逗号分隔，支持场内ETF和场外基金代码）
# 场内ETF：510050, 510300, 159915
# 场外基金：000011, 110011, 005827
FUND_LIST=510050,510300,159915,000011

# ===================================
# AI 模型配置
# ===================================

# Gemini（https://aistudio.google.com）
GEMINI_API_KEY=

# DeepSeek（https://platform.deepseek.com）
DEEPSEEK_API_KEY=

# OpenAI / 兼容 API
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Anthropic Claude
# ANTHROPIC_API_KEY=

# 硅基流动 SiliconFlow
# SILICONFLOW_API_KEY=
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Ollama 本地模型（无需 API Key）
# OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b

# LiteLLM 主模型设置
# 留空自动检测：优先使用已配置的 API Key 对应模型
LITELLM_MODEL=

# 采样温度（0.0-2.0，默认 0.7）
# LLM_TEMPERATURE=0.7

# --- 多渠道配置（可选，也可在 Web 设置页配置）---
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_MODELS=deepseek-chat
# LLM_GEMINI_API_KEY=xxx
# LLM_GEMINI_MODELS=gemini-2.5-pro

# ===================================
# 数据源配置
# ===================================

# Tushare Pro Token（可选）
# TUSHARE_TOKEN=

# AKShare 无需 Token，免费使用

# EastMoney efinance 无需 Token，免费使用

# 数据源优先级（数字越小越优先）
# EFINANCE_PRIORITY=0
# AKSHARE_PRIORITY=1
# TUSHARE_PRIORITY=2

# ===================================
# 搜索引擎配置（用于获取基金新闻）
# ===================================

# Tavily API Keys
TAVILY_API_KEYS=

# SerpAPI Keys
SERPAPI_API_KEYS=

# Brave Search API Keys
# BRAVE_API_KEYS=

# ===================================
# 通知渠道配置
# ===================================

# 企业微信机器人
# WECHAT_WEBHOOK_URL=

# 飞书机器人
# FEISHU_WEBHOOK_URL=
# FEISHU_WEBHOOK_SECRET=

# 钉钉机器人
# DINGTALK_WEBHOOK_URL=
# DINGTALK_SECRET=

# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# 邮件推送
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=

# 自定义 Webhook
# CUSTOM_WEBHOOK_URLS=

# ===================================
# 定时任务配置
# ===================================

SCHEDULE_ENABLED=false
SCHEDULE_TIME=18:00
RUN_IMMEDIATELY=true
MARKET_REVIEW_ENABLED=true

# ===================================
# WebUI 配置
# ===================================

WEBUI_ENABLED=false
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8000
WEBUI_AUTO_BUILD=true

# Web 登录认证
ADMIN_AUTH_ENABLED=false

# ===================================
# 系统配置
# ===================================

LOG_DIR=./logs
LOG_LEVEL=INFO
MAX_WORKERS=3
DEBUG=false
DATABASE_PATH=./data/fund_analysis.db

# ===================================
# 代理配置（可选）
# ===================================

USE_PROXY=false
PROXY_HOST=127.0.0.1
PROXY_PORT=10809

# ===================================
# 分析配置
# ===================================

# 报告输出语言：zh(中文) / en(英文)
REPORT_LANGUAGE=zh

# 报告类型：simple(精简) / full(完整)
REPORT_TYPE=simple

# 单只基金推送
# SINGLE_STOCK_NOTIFY=false

# 分析间隔（秒），避免 API 限流
# ANALYSIS_DELAY=0
